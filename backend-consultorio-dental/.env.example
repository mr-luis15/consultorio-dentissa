# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# Prisma usa esta URL para conectarse a la base de datos.
# • Dentro de Docker: el host es "sqlserver" (nombre del servicio en docker-compose.yml)
# • En local sin Docker: usa "localhost" o la IP de tu servidor
DATABASE_URL="sqlserver://localhost:1433;database=consultorio_dentissa;user=SA;password=12345;encrypt=true;trustServerCertificate=true"

DATABASE_HOST=localhost
DATABASE_PORT=1433
DATABASE_NAME=consultorio_dentissa
DATABASE_USER=SA
# La contraseña de SQL Server debe tener al menos 8 caracteres,
# mayúsculas, minúsculas y un número o símbolo (requisito de MSSQL)
DATABASE_PASSWORD=12345

ON_PRODUCTION=false
